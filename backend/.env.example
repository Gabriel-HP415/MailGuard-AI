# ============================================
# MailGuard-AI — Backend Environment Example
# ============================================
# Copy this file to `.env` and fill in real values.
# ============================================

# Application
APP_NAME=MailGuard-AI
APP_ENV=development
APP_DEBUG=true
APP_VERSION=1.0.0

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_URL=http://localhost:8000

# Database (MySQL 8)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mailguard_ai
DB_USER=mailguard
DB_PASSWORD=change_me_in_production

# Override this if you prefer supplying the full URL (useful for Docker):
# DATABASE_URL=mysql+pymysql://mailguard:change_me_in_production@db:3306/mailguard_ai?charset=utf8mb4

# JWT
JWT_SECRET_KEY=replace_with_long_random_string_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5500,chrome-extension://*

# Rate limiting
RATE_LIMIT_PER_MINUTE=120

# AI Service
AI_MODEL_DIR=../ai_service/models/artifacts
ACTIVE_MODEL_VERSION=auto
DISTILBERT_MODEL_NAME=distilbert-base-uncased
MAX_SEQUENCE_LENGTH=256

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Admin bootstrap (used by `python -m app.database.seed`)
ADMIN_EMAIL=admin@mailguard.ai
ADMIN_PASSWORD=ChangeMe123!

# ============================================
# Firebase Authentication (Chrome extension)
# ============================================
# When FIREBASE_ENABLED=true the backend will verify Firebase ID tokens from
# the extension via `firebase-admin`. Leave disabled in environments where
# only the legacy email/password flow is used.
FIREBASE_ENABLED=true
FIREBASE_PROJECT_ID=mailguard-ai-a7f0a
FIREBASE_CREDENTIALS_PATH=secrets/firebase-service-account.json
# Public Web API key — find it at Firebase Console > Project settings > General > Your apps > Web app.
FIREBASE_WEB_API_KEY=AIzaSyDKmMoGt3dmnpbCtFura-GOx_Hg-8M7--8
# OAuth client (Web application type) registered with the Chrome extension's
# chromiumapp.org redirect URI.
FIREBASE_OAUTH_CLIENT_ID=431641720493-co8nefc95oub7k7gvha196kjl8i7ia6e.apps.googleusercontent.com