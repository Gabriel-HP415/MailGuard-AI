# MailGuard-AI — environment variables
# Copy this file to `.env` and edit values before running `docker compose up`.

# --- General ---
APP_ENV=production
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8080

# --- MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mailguard_ai
DB_USER=mailguard
DB_PASSWORD=mailguard
DB_ROOT_PASSWORD=rootpass

# --- Backend API ---
BACKEND_PORT=8000
JWT_SECRET_KEY=change_me_to_a_long_random_string_min_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
FRONTEND_URL=http://localhost:8080
RATE_LIMIT_PER_MINUTE=120
AI_SERVICE_URL=http://ai_service:8001

# --- AI Service ---
AI_PORT=8001
INFERENCE_DEVICE=cpu
# AI_PROVIDER: stub (default, no external AI needed), http (calls ai_service), gemini (needs GEMINI_API_KEY)
AI_PROVIDER=stub
AB_TEST_ENABLED=false
AB_TEST_CHALLENGER=
AB_TEST_WEIGHT_B=0.2

# --- Frontend ---
FRONTEND_PORT=8080
MAILGUARD_API_BASE_URL=http://localhost:8000/api/v1