# MailGuard-AI Environment Variables (example)
# Copy this file to `.env` and fill in real values.

# ---------- General ----------
APP_NAME=MailGuard-AI
APP_ENV=development        # development | production
APP_DEBUG=True
APP_VERSION=1.0.0

# ---------- Backend ----------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_URL=http://localhost:8000

# ---------- Database (MySQL) ----------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=mailguard_ai
DB_USER=mailguard
DB_PASSWORD=change_me_in_production
DB_ROOT_PASSWORD=change_me_in_production

# SQLAlchemy
DATABASE_URL=mysql+pymysql://mailguard:change_me_in_production@localhost:3306/mailguard_ai

# ---------- Authentication ----------
JWT_SECRET_KEY=replace_with_a_long_random_string_min_64_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440   # 24h

# ---------- CORS ----------
CORS_ORIGINS=http://localhost:3000,http://localhost:5500,chrome-extension://*

# ---------- Rate Limiting ----------
RATE_LIMIT_PER_MINUTE=120

# ---------- AI Service ----------
AI_MODEL_DIR=../ai_service/models/artifacts
ACTIVE_MODEL_VERSION=auto
DISTILBERT_MODEL_NAME=distilbert-base-uncased
MAX_SEQUENCE_LENGTH=256

# ---------- Logging ----------
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ---------- Admin Bootstrap ----------
ADMIN_EMAIL=admin@mailguard.ai
ADMIN_PASSWORD=ChangeMe123!